from transformers import pipeline
import torch

pipe = pipeline(
    "text-generation",
    model=model,
    tokenizer=tokenizer,
    device_map="auto",
    torch_dtype=torch.bfloat16,
)

def is_similar(output, ref):
    # très simple : on vérifie surtout que le format est respecté
    out = output.lower()
    ref = ref.lower()
    if "score" not in out or "points forts" not in out or "points faibles" not in out:
        return 0.0
    return 1.0

correct = 0
total = 0

for item in val_dataset:
    prompt = item["text"]             # ton input (CV + offre)
    # tu as besoin de la réponse attendue "ground truth"
    # si tu ne l’as pas, tu peux te limiter à la conformité de format
    outputs = pipe(prompt, max_new_tokens=512)
    output = outputs[0]["generated_text"]
    correct += is_similar(output, prompt)   # ici tu pourrais comparer avec une vraie réponse
    total += 1

accuracy = correct / total
print(f"Approx accuracy (format) = {accuracy:.2f}")


