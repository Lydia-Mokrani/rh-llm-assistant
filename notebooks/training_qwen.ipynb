import json, os, subprocess, torch
from transformers import pipeline
from collections import Counter

# Cloner si nécessaire
if not os.path.exists("rh-llm-assistant"):
    subprocess.run(["git", "clone", "https://github.com/Lydia-Mokrani/rh-llm-assistant.git"], check=True)

# Charger le test set
test_data = []
with open("rh-llm-assistant/dataset/processed/test_final.jsonl", "r", encoding="utf-8") as f:
    for line in f:
        test_data.append(json.loads(line))

pipe = pipeline(
    "text-generation",
    model=model,
    tokenizer=tokenizer,
    max_new_tokens=500,
    temperature=0.0,
    do_sample=False
)

def extraire_verdict(texte):
    upper = texte.upper()
    if "NON RECOMMANDÉ" in upper or "NON RECOMMANDE" in upper:
        return "non_recommande"
    elif "BON CANDIDAT" in upper or "RECOMMANDÉ POUR ENTRETIEN" in upper:
        return "recommande"
    elif "POTENTIEL" in upper or "FORMATION" in upper:
        return "potentiel"
    else:
        mots_negatifs = ["junior", "insuffisant", "décalé", "trop peu", "manque", "negative", "not"]
        mots_positifs = ["solide", "compétent", "expérimenté", "pertinent", "positive"]
        score_neg = sum(1 for m in mots_negatifs if m in texte.lower())
        score_pos = sum(1 for m in mots_positifs if m in texte.lower())
        if score_neg > score_pos:
            return "non_recommande"
        elif score_pos > score_neg:
            return "recommande"
        else:
            return "potentiel"

correct = 0
total = 0
erreurs = []

for i, exemple in enumerate(test_data[:50]):
    messages_input = exemple["messages"][:2]
    attendu_raw = exemple["messages"][2]["content"]
    attendu = extraire_verdict(attendu_raw)
    
    text = tokenizer.apply_chat_template(messages_input, tokenize=False, add_generation_prompt=True)
    result = pipe(text)
    reponse = result[0]["generated_text"].split("<|im_start|>assistant")[-1].strip()
    predit = extraire_verdict(reponse)
    
    if attendu == predit:
        correct += 1
    else:
        erreurs.append({"attendu": attendu, "predit": predit})
    
    total += 1
    if (i+1) % 10 == 0:
        print(f"  {i+1}/50 — accuracy : {round(correct/(i+1)*100, 1)}%")

print(f"\n✅ Accuracy finale : {correct}/{total} = {round(correct/total*100, 1)}%")
print(f"❌ Erreurs : {len(erreurs)}")
print("\nErreurs par type :")
for e in erreurs[:5]:
    print(f"  Attendu: {e['attendu']} → Prédit: {e['predit']}")


